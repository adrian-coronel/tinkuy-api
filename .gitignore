# Ignore Visual Studio temporary files, build results, and files generated by add-ons
*.user
*.suo
*.vs
*.userosscache
*.sln.docstates
# Build results
[Dd]ebug/
[Rr]elease/
[Bb]in/
[Oo]bj/
# Visual Studio cache/options directory
vs/
# MSTest test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
# NuGet Packages
*.nupkg
**/packages/*
!**/packages/build/
# Azure and publish settings
*.Publish.xml
*.azurePubxml
*.pubxml
*.publishproj
# Node.js dependencies
node_modules/
# Others
*.log
*.tmp
*.pdb
*.cachefile
# Secrets — nunca subir al repo
appsettings.Development.json
# Rider IDE files
idea/